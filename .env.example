# Database — Supabase (project: gibfxdovakztgesqwvtu, region: us-west-2)
#
# ⚠️ Vercel is IPv4-only — direct connection (db.xxx.supabase.co:5432) WILL NOT WORK
#
# Get connection strings from the **Connect** button (top of Supabase project page):
# https://supabase.com/dashboard/project/gibfxdovakztgesqwvtu?showConnect=true
#
# Option A — Transaction mode (best for Vercel + Prisma, port 6543):
# postgresql://postgres.gibfxdovakztgesqwvtu:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=1
#
# Option B — Session pooler (if transaction isn't listed, port 5432 on POOLER host):
# postgresql://postgres.gibfxdovakztgesqwvtu:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=1
#
# ❌ NEVER use on Vercel: db.gibfxdovakztgesqwvtu.supabase.co:5432 (direct — IPv6 only)

DATABASE_URL="postgresql://postgres.gibfxdovakztgesqwvtu:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=1"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-secret"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# API Server
API_PORT=4000
API_URL="http://localhost:4000"

# Storage (Supabase or S3)
STORAGE_PROVIDER="local"
SUPABASE_URL="https://gibfxdovakztgesqwvtu.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
